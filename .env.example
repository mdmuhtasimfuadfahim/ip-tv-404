# ── Backend ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Frontend (Vite) ──────────────────────────────────
# Base URL for GitHub Pages: set to /ip-tv-404/
# For VPS root deploy: leave as /
VITE_BASE_URL=/

# Proxy URL — set to your Cloudflare Worker or backend proxy
# GitHub Pages mode: VITE_PROXY_URL=https://iptv-worldcup-proxy.YOUR_WORKER.workers.dev
# Self-hosted mode:  VITE_PROXY_URL=https://yourdomain.com/api/proxy
VITE_PROXY_URL=https://mdmuhtasimfuadfahim.github.io/ip-tv-404/
